# =============================================================================
# .env.sample — API keys and environment variables for the book's labs.
#
# To run the labs locally:
#   1. Copy this file to ".env" in the same directory.
#   2. Replace each "your_..._here" placeholder with a real key.
#   3. The labs will pick up the values either through `python-dotenv`
#      (already imported by `common.py` in every chapter folder) or
#      directly from the process environment.
#
# To run the labs in Google Colab:
#   Ignore this file. Instead, add each key in the Colab left sidebar
#   under the *key* icon, using the **same names** listed below. The
#   notebooks call `google.colab.userdata.get('<NAME>')` to fetch them.
#
# Each section below lists which labs need which key. You only need to
# fill in the keys for the labs you intend to run.
# =============================================================================


# -----------------------------------------------------------------------------
# OpenAI — used by most labs across every chapter.
# Get one at: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
# Labs: Ch 1 (all), Ch 2 (most), Ch 3 (Labs 1, 3, 4, 5, 6, 9),
#       Ch 5 (Lab 1, Lab 2), Ch 7 (all), Ch 9 (Lab 1, Lab 2).
OPENAI_API_KEY=your_openai_api_key_here


# -----------------------------------------------------------------------------
# Anthropic (Claude) — used by Ch 1 Lab 1 and Ch 3 Lab 7.
# Get one at: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# -----------------------------------------------------------------------------
# Google AI Studio (Gemini) — used by Ch 1 Lab 1 and Ch 3 Lab 2 (Google ADK).
# Get one at: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here


# -----------------------------------------------------------------------------
# Mistral — Ch 3 Lab 8 only.
# Get one at: https://console.mistral.ai/api-keys/
# -----------------------------------------------------------------------------
MISTRAL_API_KEY=your_mistral_api_key_here


# -----------------------------------------------------------------------------
# NewsAPI — Ch 1 Lab 3 only (agentic vs non-agentic comparison).
# Free tier available. Get one at: https://newsapi.org/register
# -----------------------------------------------------------------------------
NEWS_API_KEY=your_newsapi_key_here


# -----------------------------------------------------------------------------
# Financial Modeling Prep — Ch 2 Labs 1 and 6.
# Also used by the *production* (non-stub) implementations of Ch 7 and Ch 9
# in the source repositories. The Ch 7/9 *labs* in this repo use stub data
# and do NOT need this key to run.
# Free tier available. Get one at: https://financialmodelingprep.com/developer/docs
# -----------------------------------------------------------------------------
FINANCIAL_MODELING_PREP_API_KEY=your_fmp_api_key_here


# -----------------------------------------------------------------------------
# Optional — only needed if you swap the Ch 5 stub tools for the real ones
# (described in the chapter text but not wired into the notebooks).
# -----------------------------------------------------------------------------
# Financial Datasets API — quantitative metrics for Ch 5 deep search.
# https://docs.financialdatasets.ai/
FINANCIAL_DATASETS_API_KEY=your_financial_datasets_api_key_here

# Tavily — web search for Ch 5 deep search.
# https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# SEC EDGAR — for the real SEC filings tool in Ch 5. EDGAR requires
# a User-Agent that includes a contact email, not an API key. The default
# in common.py is "researcher@example.com" but you should set your own.
SEC_EDGAR_EMAIL=your_email@example.com
